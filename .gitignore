# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
ENV/

# Match dump from remote sync — regenerate via dashboard sync or sync_remote_results (often huge).
retro_results.json

# Access / KOATD source dumps (often private/binary)
*.mdb
*.accdb

# Local SQLite databases (generated by tooling; keep dumps out of history if huge)
/data/*.sqlite
/data/*.sqlite3
# Amiga 500 KOATD CSV bundle — may be tracked so Streamlit Cloud can ship them (online SQLite stays ignored).
!/data/offline_koatd.sqlite3
!/data/koatd_scores_export.csv
!/data/koatd_tournament_players_export.csv
/data/*.db
/data/results_sync_manifest.json
/data/.cloud_auto_bootstrap_attempted

# Jupyter / tooling
.ipynb_checkpoints/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Secrets & local overrides
.env
.env.*
!.env.example

# Streamlit (never commit populated secrets.toml)
.streamlit/secrets.toml
